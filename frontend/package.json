{
  "name": "geo-hearo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "optimize-geo": "mapshaper public/data/ne_countries.geojson -o force precision=0.001 public/data/ne_countries.geojson",
    "minify": "find public/data -type f \\( -name '*.json' -o -name '*.geojson' \\) -exec sh -c 'jq -c . \"$1\" > \"$1.tmp\" && mv \"$1.tmp\" \"$1\"' _ {} \\;",
    "show-size": "ls -lh public/data",
    "prebuild": "bun run show-size && bun run optimize-geo && bun run minify && bun run show-size"
  },
  "dependencies": {
    "@plausible-analytics/tracker": "^0.4.4",
    "@supabase/supabase-js": "^2.99.3",
    "@turf/area": "^7.3.3",
    "@turf/boolean-intersects": "^7.3.3",
    "@turf/distance": "^7.3.3",
    "@turf/explode": "^7.3.3",
    "@turf/helpers": "^7.3.3",
    "driver.js": "^1.4.0",
    "geojson": "^0.5.0",
    "lucide-vue-next": "^0.562.0",
    "maplibre-gl": "^5.15.0",
    "pinia": "^3.0.4",
    "vant": "^4.9.22",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.10",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "jsdom": "^28.0.0",
    "mapshaper": "^0.6.113",
    "oxfmt": "^0.40.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.17",
    "vue-tsc": "^3.1.4"
  }
}
